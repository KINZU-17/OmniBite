# Copy to .env and fill in. .env is gitignored.

# Postgres
DATABASE_URL="postgresql://omnibite:omnibite@localhost:5432/omnibite?schema=public"

# App
PORT=3000
NODE_ENV=development

# M-Pesa (Daraja) — sandbox until production credentials are issued
MPESA_BASE_URL="https://sandbox.safaricom.co.ke"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://example.com/mpesa/callback"

# eTIMS (KRA) — OSCU endpoint or licensed integrator
ETIMS_BASE_URL=""
ETIMS_API_KEY=""

# Pesapal (card) — API v3. Sandbox base: https://cybqa.pesapal.com/pesapalv3
# Production base: https://pay.pesapal.com/v3. PESAPAL_IPN_ID is the id returned
# when registering PESAPAL_CALLBACK_URL's host as an IPN URL.
PESAPAL_BASE_URL="https://cybqa.pesapal.com/pesapalv3"
PESAPAL_CONSUMER_KEY=""
PESAPAL_CONSUMER_SECRET=""
PESAPAL_IPN_ID=""
PESAPAL_CALLBACK_URL="https://example.com/card/return"
PESAPAL_CURRENCY="KES"
